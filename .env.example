# ParaHelper - Environment Variables
# Copy this file to .env and fill in your actual values
# Windows: copy .env.example .env
# Mac/Linux: cp .env.example .env

# Required - AI (use one)
# OPENROUTER_API_KEY: Chat + embeddings via OpenRouter. No Gemini needed.
OPENROUTER_API_KEY=your_openrouter_key
# GOOGLE_GEMINI_API_KEY: Alternative - direct Gemini for chat + embeddings. Use if not using OpenRouter.
GOOGLE_GEMINI_API_KEY=your_gemini_key

# Required - Database
MONGODB_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/

# Required - ChromaDB (medical knowledge vector DB)
CHROMA_URL=http://localhost:8000

# Required - Auth
JWT_SECRET=your_random_secret_string

# Optional - Voice (ElevenLabs TTS)
ELEVENLABS_API_KEY=your_elevenlabs_key

# Email - forms go to Hillsidesplc@gmail.com (challenge requirement)
FORM_RECIPIENT_EMAIL=Hillsidesplc@gmail.com

# Option A: Gmail SMTP (recommended for demos - most reliable)
# Enable 2FA on Gmail, then create App Password: myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Option B: SendGrid (requires SENDER_EMAIL to be verified in SendGrid dashboard)
SENDGRID_API_KEY=your_sendgrid_key
# Must match a verified Single Sender in SendGrid
SENDER_EMAIL=your_verified@email.com

# Optional - Weather (login briefing uses real conditions; station maps to city)
OPENWEATHER_API_KEY=your_openweather_key
# OPENWEATHER_CITY=Barrie,CA   # fallback if station not in mapping

# Optional - Maps (backend: hospital lookup + directions when AI recommends a hospital)
# Also add REACT_APP_MAPBOX_TOKEN to frontend/.env for the Map UI
MAPBOX_TOKEN=your_mapbox_token

# Server
PORT=5000

# Frontend (optional)
REACT_APP_API_URL=http://localhost:5000
